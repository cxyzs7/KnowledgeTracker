# Copy to .env and fill in your values
# Never commit .env to git

# Required
ANTHROPIC_API_KEY=your-anthropic-api-key

# Required for web search
TAVILY_API_KEY=your-tavily-api-key

# Optional sources — each is silently skipped when its credentials are absent
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password
SUPADATA_API_KEY=your-supadata-api-key
X_BEARER_TOKEN=your-x-bearer-token

# Override vault path (used by GitHub Actions, optional locally)
# VAULT_PATH=/path/to/your/obsidian/vault

# Skip HuggingFace Hub network checks on every run (set after first run once model is cached)
# HF_HUB_OFFLINE=1
